{
  "name": "@exre/exui",
  "version": "0.0.0",
  "description": "Exre brand React component library built on shadcn/ui and Radix UI.",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "main": "./dist/exui.js",
  "module": "./dist/exui.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/exui.js"
    },
    "./style.css": {
      "types": "./types/index.css.d.ts",
      "default": "./dist/index.css"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "types",
    "src/components",
    "src/hooks",
    "src/lib",
    "src/index.css",
    "src/index.ts",
    "components.json",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json --noEmit && vite build && node scripts/clean-types.mjs && tsc -p tsconfig.lib.json && tsc-alias -p tsconfig.lib.json && node scripts/fix-css-dts.mjs",
    "lint": "oxlint",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "preview": "vite preview"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@shadcn/react": "^0.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.23.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.1",
    "react-day-picker": "^10.0.1",
    "react-resizable-panels": "^4.12.0",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "react": ">=19.0.0 <20",
    "react-dom": ">=19.0.0 <20"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@fontsource-variable/outfit": "^5.2.8",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "^4.12.0",
    "tailwindcss": "^4.3.2",
    "tsc-alias": "^1.8.17",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "zod": "^3.25.28"
  },
  "sideEffects": [
    "*.css",
    "src/index.css"
  ]
}
